# ========================================
# Django Core Settings
# ========================================
# Set to False in production
DEBUG=True
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# The secret key used for cryptographic signing
SECRET_KEY=django-insecure-example-key

# ========================================
# Database Settings (PostgreSQL)
# ========================================
# The credentials for the DB container
POSTGRES_USER=remake_user
POSTGRES_PASSWORD=remake_password
POSTGRES_DB=remake_db
# URL format for Django
DATABASE_URL=postgres://remake_user:remake_password@db:5432/remake_db

# ========================================
# Redis Settings
# ========================================
# URL for Celery Broker and Channels Layer
CELERY_BROKER_URL=redis://redis:6379/0

# ========================================
# Odoo Synchronization Settings
# ========================================
# Base URL of the Odoo instance
ODOO_URL=http://odoo.local:8069
# The name of the Odoo database
ODOO_DB=odoo
# The username to connect to Odoo
ODOO_USERNAME=admin
# The password or API key to connect to Odoo
ODOO_PASSWORD=adminpassword
